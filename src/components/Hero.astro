---
import { siteConfig } from "../config/siteConfig";
const { hero } = siteConfig;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section
  class="relative flex min-h-[85vh] items-end overflow-hidden bg-[--color-crust-dark] px-6 py-20 sm:py-28"
>
  <img
    src={`${base}/images/bakes-spread.jpg`}
    alt="A spread of fresh bakes from Betty Botter's kitchen"
    class="absolute inset-0 h-full w-full object-cover"
  />
  <div
    aria-hidden="true"
    class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/10"
  >
  </div>
  <div class="relative mx-auto w-full max-w-5xl">
    <p
      class="mb-4 text-sm uppercase tracking-[0.3em] text-[--color-wheat]"
    >
      {hero.subheading}
    </p>
    <h1
      class="mb-6 text-5xl font-bold text-white drop-shadow-lg sm:text-7xl lg:text-8xl"
    >
      {hero.heading}
    </h1>
    <p class="mb-10 max-w-2xl text-lg text-white/90 drop-shadow sm:text-xl">
      {hero.tagline}
    </p>
    <a
      href="#order"
      class="inline-block rounded-full bg-[--color-cream] px-8 py-4 text-base font-semibold text-[--color-crust-dark] shadow-xl transition hover:bg-white hover:shadow-2xl"
    >
      {hero.ctaLabel}
    </a>
  </div>
</section>
<div class="flex justify-center bg-[--color-crust-dark] px-6 py-8">
  <img
    src={`${base}/images/logo.png`}
    alt="Betty Botter's Bakery"
    class="h-32 w-32 sm:h-40 sm:w-40"
  />
</div>
