---
import { siteConfig, type Product } from "../config/siteConfig";
const products: readonly Product[] = siteConfig.products;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const cardClass =
  "group flex flex-col overflow-hidden rounded-2xl bg-[--color-cream] shadow-sm transition hover:-translate-y-1 hover:shadow-md";
---

<section id="products" class="bg-[--color-cream-dark] px-6 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="mb-14 text-center">
      <h2 class="mb-3 text-4xl font-bold text-[--color-crust-dark] sm:text-5xl">
        What's Baking
      </h2>
      <p class="text-[--color-crust]">This week's bakes</p>
    </div>
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        products.map((product) => {
          const Inner = (
            <>
              {product.image ? (
                <img
                  src={`${base}/${product.image}`}
                  alt={product.name}
                  class="aspect-[4/5] w-full object-cover transition group-hover:scale-[1.02]"
                  loading="lazy"
                />
              ) : (
                <div class="flex aspect-[4/5] w-full items-center justify-center bg-[--color-wheat]/20 text-7xl">
                  <span aria-hidden="true">{product.emoji}</span>
                </div>
              )}
              <div class="flex flex-1 flex-col p-6">
                <h3 class="mb-2 text-xl font-bold text-[--color-crust-dark]">
                  {product.name}
                </h3>
                <p class="mb-4 flex-1 text-sm text-[--color-crust]">
                  {product.description}
                </p>
                <p class="text-lg font-semibold text-[--color-wheat-dark]">
                  {product.price}
                  {product.href && (
                    <span class="ml-2 text-sm font-medium text-[--color-crust] group-hover:underline">
                      View options →
                    </span>
                  )}
                </p>
              </div>
            </>
          );
          return product.href ? (
            <a href={`${base}/${product.href}`} class={cardClass}>
              {Inner}
            </a>
          ) : (
            <article class={cardClass}>{Inner}</article>
          );
        })
      }
    </div>
  </div>
</section>
