---
import { siteConfig } from "../config/siteConfig";
const { about } = siteConfig;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<section id="about" class="px-6 py-20 sm:py-28">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="mb-6 text-4xl font-bold text-[--color-crust-dark] sm:text-5xl">
      {about.heading}
    </h2>
    <p class="mb-10 text-lg leading-relaxed text-[--color-crust]">
      {about.body}
    </p>
    <figure
      class="mx-auto max-w-sm overflow-hidden rounded-2xl bg-[--color-cream] shadow-lg ring-1 ring-[--color-wheat]/40"
    >
      <img
        src={`${base}/images/info-card.jpg`}
        alt="Betty Botter's Bakery — opening days, address and how to pay"
        class="block w-full"
      />
    </figure>
  </div>
</section>
