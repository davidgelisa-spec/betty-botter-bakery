---
import { siteConfig } from "../config/siteConfig";
const year = new Date().getFullYear();
---

<footer class="bg-[--color-crust-dark] px-6 py-12 text-[--color-cream]">
  <div class="mx-auto max-w-4xl text-center">
    <p class="mb-2 font-serif text-2xl font-bold">{siteConfig.name}</p>
    <p class="text-sm text-[--color-cream]/80">
      Honesty cabinet: <span class="font-medium">{siteConfig.cabinetLocation}</span>
    </p>
    <p class="mb-4 text-sm text-[--color-cream]/80">
      Open <span class="font-medium">{siteConfig.openingDays}</span>
    </p>
    <p class="mb-4 text-sm">
      <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[--color-cream]/80 underline hover:text-[--color-cream]"
      >
        Find us on Facebook
      </a>
    </p>
    <p class="text-xs text-[--color-cream]/60">
      © {year} {siteConfig.name}
    </p>
  </div>
</footer>
