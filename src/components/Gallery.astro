---
import { siteConfig } from "../config/siteConfig";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const { gallery } = siteConfig;
---

<section class="bg-[--color-cream] px-6 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="mb-12 text-center">
      <h2 class="mb-3 text-4xl font-bold text-[--color-crust-dark] sm:text-5xl">
        A taste of Betty's baking
      </h2>
      <p class="text-[--color-crust]">
        A few of the bakes that have come out of the kitchen.
      </p>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        gallery.map((photo) => (
          <figure class="group overflow-hidden rounded-2xl shadow-sm transition hover:shadow-md">
            <img
              src={`${base}/${photo.image}`}
              alt={photo.caption}
              class="aspect-[4/5] w-full object-cover transition group-hover:scale-[1.03]"
              loading="lazy"
            />
            <figcaption class="bg-[--color-cream-dark] px-4 py-3 text-center text-sm font-medium text-[--color-crust-dark]">
              {photo.caption}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
